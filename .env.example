# ==========================================
# Configuration Boostify - Mode Production
# ==========================================

# Port du serveur (Render définit automatiquement PORT)
PORT=3000

# URL complète du site (important pour les emails et les liens)
SITE_URL=https://boostify-website.onrender.com

# ==========================================
# Base de données MongoDB
# ==========================================
# Crée une base gratuite sur MongoDB Atlas : https://www.mongodb.com/atlas
# Remplace <username>, <password>, <cluster> et <dbname>
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/boostify?retryWrites=true&w=majority

# ==========================================
# Sécurité Admin
# ==========================================
# Mot de passe pour accéder au dashboard admin
# Change ce mot de passe ! Utilise au moins 8 caractères.
ADMIN_PASSWORD=boostify2024

# Clé secrète pour signer les sessions (change cette valeur)
SESSION_SECRET=votre_cle_secrete_tres_longue_et_aleatoire

# ==========================================
# Email (Nodemailer)
# ==========================================
# Utilise Gmail, SendGrid, Mailgun, etc.
# Pour Gmail, tu dois activer l'authentification à 2 facteurs et créer un mot de passe d'application.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bellosuaibou@7gmail.com
SMTP_PASS=votre_mot_de_passe_application

# Email qui recevra les notifications de commandes
NOTIFICATION_EMAIL=bellosuaibou@7gmail.com

# Email d'expédition (généralement le même que SMTP_USER)
FROM_EMAIL=bellosuaibou@7gmail.com

# ==========================================
# WhatsApp
# ==========================================
WHATSAPP_NUMBER=2250161498523
